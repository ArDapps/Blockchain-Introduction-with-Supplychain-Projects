# Hardhat deploy settings
SUPPLIER_ADDRESS=
RECEIVER_ADDRESS=

# Sepolia deploy settings. Never commit a real private key.
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_API_KEY
SEPOLIA_PRIVATE_KEY=

# Frontend public settings copied into app/.env.local by scripts/deploy.ts
NEXT_PUBLIC_REOWN_PROJECT_ID=
NEXT_PUBLIC_INFURA_API_KEY=
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://sepolia.etherscan.io
